    document.getElementById('t-pin').value='';document.getElementById('t-pin2').value='';
  }else{
    ['t-name','t-spec','t-phone','t-pin','t-pin2'].forEach(function(i){document.getElementById(i).value=''});
    document.getElementById('t-role').value='teknisi';
  }
  document.getElementById('ov-tech').classList.add('open');
}

async function saveTech(){
  var name=document.getElementById('t-name').value.trim();
  var pin=document.getElementById('t-pin').value.trim();
  var pin2=document.getElementById('t-pin2').value.trim();
  if(!name){alert('Nama wajib diisi');return;}
  if(!currentTechEdit&&!pin){alert('PIN wajib diisi untuk pengguna baru');return;}
  if(pin&&pin!==pin2){alert('Konfirmasi PIN tidak cocok');return;}
  if(pin&&(pin.length<4)){alert('PIN minimal 4 digit');return;}
  var newRole=document.getElementById('t-role').value;
  var obj={id:currentTechEdit||genId(),name:name,role:newRole,spec:document.getElementById('t-spec').value.trim(),phone:document.getElementById('t-phone').value.trim()};
  if(pin)obj.pin=pin;
  showLoading('Menyimpan pengguna...');
  try{
    var res=await sbUpsert('technicians',obj);
    hideLoading();
    if(Array.isArray(res)||(res&&res.id)){
      closeModal('ov-tech');
      await loadTechs();
      renderTechList();
      if(currentTechEdit && currentUser && currentUser.id===currentTechEdit){
        currentUser.role=newRole; currentUser.name=name; currentUser.spec=obj.spec;
        sessionStorage.setItem('sr_user',JSON.stringify(currentUser));
        applyRoleUI();
      }
      showToast('Pengguna disimpan ('+{teknisi:'Teknisi',staff:'Staff/Kasir',admin:'Admin'}[newRole]+')');
    }else showToast('Gagal: '+(res.message||'error'),'error');
  }catch(e){hideLoading();showToast('Gagal terhubung.','error');}
}

function promptDeleteTech(id){
  var t=technicians.find(function(x){return x.id===id});if(!t)return;
  currentDelTech=id;
  var cnt=projects.filter(function(p){return p.tech===t.name}).length;
  document.getElementById('del-tech-msg').textContent='Hapus pengguna "'+t.name+'"?'+(cnt?' Ada '+cnt+' proyek terkait.':'');
  document.getElementById('ov-del-tech').classList.add('open');
}

async function confirmDeleteTech(){
  showLoading('Menghapus...');
  try{
    await sbDelete('technicians',currentDelTech);
    hideLoading();
    closeModal('ov-del-tech');await loadTechs();renderTechList();showToast('Pengguna dihapus.');
  }catch(e){hideLoading();showToast('Gagal terhubung.','error');}
}

function renderTechList(){
