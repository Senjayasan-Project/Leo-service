      <span>Progress</span><span>${prog}%</span>
    </div>

    <div class="pbar-wrap">
      <div class="pbar" style="width:${prog}%"></div>
    </div>

    <div class="igrid">
      <div class="icell"><div class="iclabel">Tanggal Input</div><div class="icval">${fmt(p.created_at)}</div></div>
      <div class="icell"><div class="iclabel">Jadwal</div><div class="icval">${fmt(p.sched)}</div></div>
      <div class="icell">
        <div class="iclabel">Target Selesai</div>
        <div class="icval" style="color:${isLate?'var(--red)':'inherit'}">${fmt(p.target)}</div>
      </div>
      <div class="icell"><div class="iclabel">Durasi</div><div class="icval">${dur}</div></div>
      <div class="icell"><div class="iclabel">Estimasi Biaya</div><div class="icval">${fmtRp(p.cost)}</div></div>
      <div class="icell"><div class="iclabel">Follow Up</div><div class="icval">${fmt(p.followup)}</div></div>
