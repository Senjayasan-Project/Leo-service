// ============================================================
function sbHeaders() {
  return {
    'Content-Type': 'application/json',
    'apikey': SUPABASE_KEY,
    'Authorization': 'Bearer ' + SUPABASE_KEY,
    'Prefer': 'return=representation'
  };
}

// GET dari tabel Supabase dengan optional query string
function sbGet(table, query) {
  var url = SUPABASE_URL + '/rest/v1/' + table + (query ? '?' + query : '');
  return fetch(url, { method: 'GET', headers: sbHeaders() }).then(function(r) { return r.json(); });
}

// INSERT satu row (upsert jika ada id sama)
function sbUpsert(table, row) {
  var url = SUPABASE_URL + '/rest/v1/' + table;
  return fetch(url, {
    method: 'POST',
    headers: Object.assign({}, sbHeaders(), { 'Prefer': 'resolution=merge-duplicates,return=representation' }),
    body: JSON.stringify(row)
  }).then(function(r) {
    if(r.status === 204) return []; // no content = success
    return r.json();
  });
}

// DELETE berdasarkan id
function sbDelete(table, id) {
  var url = SUPABASE_URL + '/rest/v1/' + table + '?id=eq.' + encodeURIComponent(id);
  return fetch(url, { method: 'DELETE', headers: sbHeaders() });
}

