<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Leo Service</title>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@600;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
:root {
  --green:#32c347;--green-dark:#2a2f6e;--green-light:#eef0f9;--green-mid:#9fa8d8;
  --blue:#185FA5;--blue-light:#E6F1FB;
  --amber:#BA7517;--amber-light:#FAEEDA;
  --red:#A32D2D;--red-light:#FCEBEB;
  --text:#1a1a18;--text2:#5a5a56;--text3:#9a9a94;
  --bg:#f5f5f2;--bg2:#ffffff;--bg3:#fafaf8;
  --border:#e4e4e0;--border2:#d0d0cc;
  --radius:8px;--radius-lg:12px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',system-ui,sans-serif;font-size:14px;color:var(--text);background:var(--bg);min-height:100vh}

/* LOGIN */
.login-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--bg);padding:20px}
.login-card{background:var(--bg2);border:1px solid var(--border);border-radius:16px;padding:40px 36px;width:100%;max-width:380px;box-shadow:0 4px 24px rgba(0,0,0,.08)}
.login-logo{text-align:center;margin-bottom:28px}
.login-logo-icon-wrap{display:flex;align-items:center;justify-content:flex-start;gap:14px;margin-bottom:10px}
.login-ls-icon{width:72px;height:72px;flex-shrink:0;display:flex;align-items:center;justify-content:center}
.login-logo-text{font-family:'Times New Roman',Times,serif;font-size:30px;font-weight:900;letter-spacing:2px;color:#3c4192;text-transform:uppercase;line-height:1.1;font-style:italic}
.login-logo-text em{color:#3c4192;font-style:italic}
.login-logo-sub{font-size:12px;color:var(--text3);margin-top:6px;letter-spacing:.3px}
.login-form{display:flex;flex-direction:column;gap:14px}
.lf-group{display:flex;flex-direction:column;gap:5px}
.lf-group label{font-size:11px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.04em}
.lf-group input,.lf-group select{padding:10px 13px;border:1px solid var(--border);border-radius:var(--radius);font-size:14px;font-family:inherit;background:var(--bg3);color:var(--text);transition:.15s}
.lf-group input:focus{outline:none;border-color:var(--green);background:#fff}
.login-btn{padding:12px;border:none;border-radius:var(--radius);background:var(--green);color:#fff;font-size:14px;font-weight:600;font-family:inherit;cursor:pointer;transition:.15s}
.login-btn:hover{background:var(--green-dark)}
.login-btn:disabled{opacity:.6;cursor:not-allowed}
.login-error{background:var(--red-light);color:var(--red);font-size:12px;padding:9px 12px;border-radius:var(--radius);border:1px solid #f0c0c0;display:none}
.login-info{background:var(--green-light);color:var(--green-dark);font-size:12px;padding:9px 12px;border-radius:var(--radius);border:1px solid var(--green-mid);display:none}
.login-users{display:flex;flex-direction:column;gap:6px}
.login-user-chip{display:flex;align-items:center;gap:8px;padding:8px 11px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius);cursor:pointer;transition:.12s}
.login-user-chip:hover{border-color:var(--green);background:var(--green-light)}
.chip-avatar{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0}
.chip-name{font-size:12px;font-weight:600}
.chip-role{font-size:10px;color:var(--text3)}
.pin-wrap{display:flex;gap:8px;justify-content:center;margin:6px 0}
.pin-dot{width:13px;height:13px;border-radius:50%;border:2px solid var(--border);transition:.15s}
.pin-dot.filled{background:var(--green);border-color:var(--green)}
.pin-numpad{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;max-width:210px;margin:0 auto}
.pin-key{padding:13px;border:1px solid var(--border);border-radius:var(--radius);background:var(--bg3);font-size:17px;font-weight:600;cursor:pointer;text-align:center;transition:.12s;font-family:inherit}
.pin-key:hover{background:var(--green-light);border-color:var(--green)}
.pin-key:active{transform:scale(.95)}
.pin-key.del{font-size:13px;color:var(--red)}

/* LOADING OVERLAY */
.loading-overlay{display:none;position:fixed;inset:0;background:rgba(255,255,255,.85);z-index:300;align-items:center;justify-content:center;flex-direction:column;gap:12px}
.loading-overlay.show{display:flex}
.spinner{width:32px;height:32px;border:3px solid var(--green-light);border-top-color:var(--green);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-msg{font-size:13px;color:var(--text2);font-weight:500}

/* APP */
.app{display:none;min-height:100vh;flex-direction:column}
.app.visible{display:flex}
.topbar{background:var(--bg2);border-bottom:1px solid var(--border);padding:0 16px;display:flex;align-items:center;gap:10px;height:50px;position:sticky;top:0;z-index:50;box-shadow:0 1px 3px rgba(0,0,0,.05)}
.logo{display:flex;align-items:center;gap:9px}
.ls-icon{width:30px;height:30px;flex-shrink:0;display:flex;align-items:center;justify-content:center}
.logo-text{font-family:'Times New Roman',Times,serif;font-size:18px;font-weight:900;letter-spacing:1px;color:#3c4192;text-transform:uppercase;font-style:italic}
.logo-text em{color:#3c4192;font-style:italic}
.pro-badge{display:none}
.api-dot{width:7px;height:7px;border-radius:50%;background:#ccc;margin-left:4px;title:"Status koneksi"}
.api-dot.ok{background:var(--green)}.api-dot.err{background:var(--red)}
.nav{display:flex;gap:2px;margin-left:auto}
.nav-btn{padding:5px 11px;border-radius:6px;border:none;background:transparent;cursor:pointer;font-size:12px;color:var(--text2);font-family:inherit;transition:.12s;white-space:nowrap}
.nav-btn.active,.nav-btn:hover{background:var(--bg3);color:var(--text);font-weight:500}
.nav-btn.active{color:var(--green-dark);font-weight:600}
.add-btn{padding:6px 14px;border-radius:6px;border:none;background:var(--green-dark);color:#fff;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;white-space:nowrap}
.add-btn:hover{background:var(--green-dark)}
.user-pill{display:flex;align-items:center;gap:7px;padding:4px 10px 4px 6px;border-radius:20px;background:var(--bg3);border:1px solid var(--border);cursor:pointer;transition:.12s}
.user-pill:hover{border-color:var(--green)}
.up-avatar{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0}
.up-name{font-size:12px;font-weight:500}
.up-role{font-size:10px;color:var(--text3);margin-left:-3px}
.content{flex:1;padding:16px}
.page{display:none}.page.active{display:block}
.metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px}
.metric{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);padding:14px 16px}
.metric-label{font-size:11px;color:var(--text3);margin-bottom:5px;font-weight:500}
.metric-value{font-size:22px;font-weight:600}
.metric-sub{font-size:11px;color:var(--text3);margin-top:3px}
.m-green{color:var(--green)}.m-amber{color:var(--amber)}.m-blue{color:var(--blue)}.m-red{color:var(--red)}
.section{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;margin-bottom:14px}
.sec-head{padding:12px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;flex-wrap:wrap;background:var(--bg3)}
.sec-title{font-weight:600;font-size:13px}
.filters{display:flex;gap:6px;margin-left:auto;flex-wrap:wrap;align-items:center}
.fsel{padding:4px 8px;border:1px solid var(--border);border-radius:6px;font-size:11px;background:var(--bg2);color:var(--text);cursor:pointer;font-family:inherit}
table{width:100%;border-collapse:collapse}
th{font-size:11px;font-weight:600;color:var(--text3);text-align:left;padding:9px 13px;border-bottom:1px solid var(--border);background:var(--bg3)}
td{padding:10px 13px;border-bottom:1px solid #f0f0ed;font-size:12px;vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:var(--bg3)}
.badge{display:inline-block;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:600}
.b-pend{background:#FAEEDA;color:#854F0B}.b-proc{background:#E6F1FB;color:#185FA5}
.b-done{background:#EAF3DE;color:#3B6D11}.b-paid{background:#E1F5EE;color:#0F6E56}.b-late{background:#FCEBEB;color:#A32D2D}
.abtn{padding:3px 8px;border:1px solid var(--border);border-radius:5px;background:transparent;font-size:10px;cursor:pointer;color:var(--text2);margin-right:3px;font-family:inherit;transition:.1s}
.abtn:hover{background:var(--bg3)}.abtn.g{border-color:var(--green);color:var(--green-dark)}.abtn.r{border-color:var(--red);color:var(--red)}.abtn.b{border-color:var(--blue);color:var(--blue)}
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.42);z-index:200;align-items:center;justify-content:center;padding:16px}
.overlay.open{display:flex}
.modal{background:var(--bg2);border-radius:14px;border:1px solid var(--border);width:490px;max-height:86vh;overflow-y:auto;padding:24px;box-shadow:0 8px 32px rgba(0,0,0,.12)}
.modal-sm{width:340px}
.mtitle{font-weight:600;font-size:15px;margin-bottom:18px}
.fgrid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.full{grid-column:1/-1}
.fg{display:flex;flex-direction:column;gap:5px}
.fg label{font-size:11px;color:var(--text2);font-weight:600;text-transform:uppercase;letter-spacing:.03em}
.fg input,.fg select,.fg textarea{padding:8px 10px;border:1px solid var(--border);border-radius:var(--radius);font-size:13px;background:var(--bg2);color:var(--text);font-family:inherit;transition:.15s}
.fg input:focus,.fg select:focus,.fg textarea:focus{outline:none;border-color:var(--green)}
.fg textarea{resize:vertical;min-height:64px}
.mfooter{display:flex;gap:8px;justify-content:flex-end;margin-top:18px;padding-top:14px;border-top:1px solid var(--border)}
.bcnl{padding:8px 16px;border:1px solid var(--border);border-radius:var(--radius);background:transparent;font-size:12px;cursor:pointer;color:var(--text2);font-family:inherit}
.bsave{padding:8px 16px;border:none;border-radius:var(--radius);background:var(--green-dark);color:#fff;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit}
.bsave:hover{background:var(--green-dark)}
.bdanger{padding:8px 16px;border:none;border-radius:var(--radius);background:var(--red);color:#fff;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit}
.detail-panel{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);padding:18px;margin-bottom:14px;display:none}
.detail-panel.open{display:block}
.dhead{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px}
.dtitle{font-weight:600;font-size:14px}.dsub{font-size:11px;color:var(--text2);margin-top:3px}
.xbtn{background:none;border:none;font-size:20px;cursor:pointer;color:var(--text3);line-height:1;padding:0 4px}
.pbar-wrap{background:var(--bg3);border-radius:20px;height:5px;margin:6px 0 14px}
.pbar{height:5px;border-radius:20px;background:var(--green);transition:width .4s}
.igrid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px}
.icell{background:var(--bg3);border-radius:var(--radius);padding:9px 12px;border:1px solid var(--border)}
.iclabel{font-size:10px;color:var(--text3);margin-bottom:3px;font-weight:500}.icval{font-size:12px;font-weight:600}
.tl{border-left:2px solid var(--border);margin-left:6px;padding-left:14px}
.tli{position:relative;margin-bottom:10px}
.tli::before{content:'';position:absolute;left:-20px;top:4px;width:7px;height:7px;border-radius:50%;background:var(--border2);border:2px solid var(--bg2)}
.tli.done::before{background:var(--green)}
.tl-date{font-size:10px;color:var(--text3)}.tl-text{font-size:12px;margin-top:1px}
.fu-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:12px 14px;margin-bottom:8px;display:flex;align-items:center;gap:10px}
.fu-date{min-width:76px;font-size:11px;font-weight:600}.fu-date.today{color:var(--green)}.fu-date.ov{color:var(--red)}
.fu-info{flex:1}.fu-proj{font-size:12px;font-weight:600}.fu-det{font-size:11px;color:var(--text3);margin-top:1px}
.chart-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
.chart-box{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);padding:16px}
.ctitle{font-size:13px;font-weight:600;margin-bottom:14px}
.bar-row{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.bar-label{font-size:11px;color:var(--text2);min-width:80px;text-align:right}
.bar-track{flex:1;background:var(--bg3);border-radius:20px;height:8px}
.bar-fill{height:8px;border-radius:20px;background:var(--green)}
.bar-val{font-size:11px;font-weight:600;min-width:24px}
.donut-wrap{display:flex;align-items:center;gap:16px}
.legend{display:flex;flex-direction:column;gap:7px}
.leg-item{display:flex;align-items:center;gap:7px;font-size:11px}.leg-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.tech-list-wrap{display:flex;flex-direction:column;gap:8px;padding:14px}
.tech-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:12px 14px;display:flex;align-items:center;gap:12px}
.tech-avatar{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;flex-shrink:0}
.tech-info{flex:1}.tech-name{font-size:13px;font-weight:600}.tech-stat{font-size:11px;color:var(--text3);margin-top:2px}
.export-bar{display:flex;gap:7px;flex-wrap:wrap}
.exp-btn{padding:6px 12px;border-radius:6px;border:1px solid var(--border);background:var(--bg2);font-size:11px;cursor:pointer;color:var(--text);display:flex;align-items:center;gap:5px;font-weight:500;font-family:inherit;transition:.12s}
.exp-btn:hover{background:var(--bg3)}.exp-btn.excel{border-color:var(--green);color:var(--green-dark)}.exp-btn.pdf{border-color:var(--red);color:var(--red)}
.role-banner{background:var(--green-light);border:1px solid var(--green-mid);border-radius:var(--radius);padding:8px 14px;font-size:12px;color:var(--green-dark);margin-bottom:14px;display:none}
.empty{padding:36px;text-align:center;color:var(--text3);font-size:12px}
.toast{position:fixed;bottom:20px;right:20px;background:var(--text);color:#fff;padding:9px 16px;border-radius:8px;font-size:12px;font-weight:500;z-index:999;opacity:0;transition:opacity .3s;pointer-events:none}
.toast.show{opacity:1}
.sync-bar{font-size:11px;color:var(--text3);display:flex;align-items:center;gap:6px;padding:4px 8px;background:var(--bg3);border-radius:20px;border:1px solid var(--border)}
.sync-bar.syncing{color:var(--amber)}.sync-bar.ok{color:var(--green)}.sync-bar.err{color:var(--red)}
@media(max-width:640px){.metrics{grid-template-columns:1fr 1fr}.chart-row{grid-template-columns:1fr}.fgrid{grid-template-columns:1fr}.igrid{grid-template-columns:1fr 1fr}}
</style>
</head>
<body>

<!-- LOADING -->
<div class="loading-overlay" id="loading-overlay">
  <div class="spinner"></div>
  <div class="loading-msg" id="loading-msg">Menghubungkan ke database...</div>
</div>

<!-- LOGIN -->
<div class="login-wrap" id="login-page">
  <div class="login-card">
    <div class="login-logo" style="text-align:left">
      <div class="login-logo-icon-wrap">
        <div class="login-ls-icon"><img src="data:image/png;base64," style="width:72px;height:72px;object-fit:contain;" alt="Leo Service Logo"></div>
        <div class="login-logo-text">Leo<br><em>Service</em></div>
      </div>
      <div class="login-logo-sub">Sistem Manajemen Jasa Service</div>
    </div>

    <!-- Step 1: Pilih user -->
    <div id="step-user" class="login-form">
      <div style="font-size:12px;font-weight:600;color:var(--text2);margin-bottom:2px">Pilih nama Anda</div>
      <div class="login-users" id="user-chips">
        <div style="text-align:center;padding:16px;color:var(--text3);font-size:12px">
          <div class="spinner" style="margin:0 auto 8px;width:20px;height:20px;border-width:2px"></div>
          Memuat daftar pengguna...
        </div>
      </div>
      <div style="margin:6px 0;text-align:center;font-size:11px;color:var(--text3)">— atau ketik manual —</div>
      <div class="lf-group">
        <label>Nama Pengguna</label>
        <input id="login-name" placeholder="Ketik nama Anda..." autocomplete="off" onkeydown="if(event.key==='Enter')goToPIN()">
      </div>
      <button class="login-btn" id="btn-lanjut" onclick="goToPIN()">Lanjut →</button>
      <div class="login-error" id="err-user"></div>
      <div class="login-info" id="info-user"></div>
    </div>

    <!-- Step 2: PIN -->
    <div id="step-pin" class="login-form" style="display:none">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px">
        <button onclick="backToUser()" style="background:none;border:1px solid var(--border);border-radius:6px;padding:4px 10px;cursor:pointer;font-size:12px;font-family:inherit;color:var(--text2)">← Kembali</button>
        <span style="font-size:13px;font-weight:600" id="pin-greeting"></span>
      </div>
      <div style="text-align:center;font-size:12px;color:var(--text3);margin-bottom:4px">Masukkan PIN Anda</div>
      <div class="pin-wrap" id="pin-dots">
        <div class="pin-dot" id="d0"></div><div class="pin-dot" id="d1"></div>
        <div class="pin-dot" id="d2"></div><div class="pin-dot" id="d3"></div>
      </div>
      <div class="pin-numpad">
        <button class="pin-key" onclick="pinKey('1')">1</button>
        <button class="pin-key" onclick="pinKey('2')">2</button>
        <button class="pin-key" onclick="pinKey('3')">3</button>
        <button class="pin-key" onclick="pinKey('4')">4</button>
        <button class="pin-key" onclick="pinKey('5')">5</button>
        <button class="pin-key" onclick="pinKey('6')">6</button>
        <button class="pin-key" onclick="pinKey('7')">7</button>
        <button class="pin-key" onclick="pinKey('8')">8</button>
        <button class="pin-key" onclick="pinKey('9')">9</button>
        <button class="pin-key" onclick="pinKey('0')" style="grid-column:2">0</button>
        <button class="pin-key del" onclick="pinDel()">⌫</button>
      </div>
      <div class="login-error" id="err-pin" style="margin-top:8px"></div>
    </div>
  </div>
</div>

<!-- APP -->
<div class="app" id="main-app">
  <div class="topbar">
    <div class="logo"><div class="ls-icon"><img src="data:image/png;base64," style="width:30px;height:30px;object-fit:contain;" alt="Leo Service Logo"></div><div class="logo-text">Leo <em>Service</em></div></div>
    <div class="api-dot" id="api-dot" title="Status koneksi Google Sheets"></div>
    <nav class="nav">
      <button class="nav-btn active" onclick="showPage('dashboard')">Dashboard</button>
      <button class="nav-btn" onclick="showPage('projects')">Proyek</button>
      <button class="nav-btn" onclick="showPage('followup')">Follow Up</button>
      <button class="nav-btn admin-only" onclick="showPage('teknisi')">Teknisi</button>
      <button class="nav-btn admin-only" onclick="showPage('analitik')">Analitik</button>
    </nav>
    <div class="sync-bar" id="sync-bar">● Terhubung</div>
    <button class="add-btn admin-only" onclick="openModal()">+ Proyek Baru</button>
    <div class="user-pill" onclick="openUserMenu()">
      <div class="up-avatar" id="up-avatar"></div>
      <div><div class="up-name" id="up-name"></div><div class="up-role" id="up-role"></div></div>
    </div>
  </div>

  <div class="content">
    <!-- DASHBOARD -->
    <div id="page-dashboard" class="page active">
      <div class="role-banner" id="role-banner"></div>
      <div class="metrics">
        <div class="metric"><div class="metric-label">Proyek Aktif</div><div class="metric-value m-blue" id="m-active">0</div><div class="metric-sub">sedang berjalan</div></div>
        <div class="metric"><div class="metric-label">Selesai Bulan Ini</div><div class="metric-value m-green" id="m-done">0</div></div>
        <div class="metric"><div class="metric-label">Tunggu Bayar</div><div class="metric-value m-amber" id="m-unpaid">0</div></div>
        <div class="metric"><div class="metric-label">Follow Up Hari Ini</div><div class="metric-value m-red" id="m-fu">0</div></div>
      </div>
      <div id="detail-panel" class="detail-panel"></div>
      <div class="section">
        <div class="sec-head">
          <span class="sec-title" id="dash-title">Proyek</span>
          <button class="abtn" onclick="loadProjects()" style="margin-left:4px">↻ Refresh</button>
