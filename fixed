async function saveProject(){
  var customer=document.getElementById('f-cust').value.trim();
  if(!customer){alert('Nama customer wajib diisi');return;}
  var btn=document.getElementById('btn-save-proj');
  btn.disabled=true;btn.textContent='Menyimpan...';

  var ep = currentEdit ? projects.find(function(x){return x.id===currentEdit}) : null;
  var newActivity = {date:today(),text:(currentEdit?'Proyek diperbarui':'Proyek dibuat')+' oleh '+currentUser.name,done:true};
  var timeline = ep ? (ep.timeline||[]).concat([newActivity]) : [newActivity];

  var obj={
    id: currentEdit||genId(),
    customer: customer,
    description: document.getElementById('f-description').value.trim(),
    tech: document.getElementById('f-tec').value,
    priority: document.getElementById('f-pri').value,
    sched: document.getElementById('f-sch').value||null,
    target: document.getElementById('f-tgt').value||null,
    cost: parseFloat(document.getElementById('f-cost').value)||0,
    notes: document.getElementById('f-note').value.trim(),
    status: ep ? ep.status : 'Dijadwalkan',
    created_at: ep ? ep.created_at : today(),
    followup: document.getElementById('f-sch').value||null,
    timeline: JSON.stringify(timeline),
    done_at: ep ? (ep.done_at||null) : null
  };

  try {
    var res = await sbUpsert('projects', obj);
    // Supabase returns array on success (may be empty []), error object on failure
    if(Array.isArray(res)){
      showToast('Proyek disimpan ke Supabase!');
      closeModal('ov-proj');
      await loadProjects();
    } else {
      var errMsg = (res && res.message) ? res.message : JSON.stringify(res);
      showToast('Gagal menyimpan: '+errMsg,'error');
      console.error('saveProject error:', res);
    }
  } catch(e){
    showToast('Gagal terhubung ke Supabase.','error');
  }
  btn.disabled=false;btn.textContent='Simpan';
}

function openStatusModal(id){
  var p=projects.find(function(x){return x.id===id});if(!p)return;
  var allowed=statusOrder;
  if(isTech())allowed=['Proses','Selesai'];
  if(isStaff())allowed=['Lunas'];
  document.getElementById('status-opts').innerHTML=statusOrder.map(function(s){
    var isActive=p.status===s;
    var canChange=allowed.indexOf(s)>=0||isActive;
    return '<button onclick="setStatus(\''+id+'\',\''+s+'\')" '+(canChange?'':'disabled')+
      ' style="padding:10px 12px;border-radius:7px;border:1px solid '+(isActive?'var(--green)':'var(--border)')+
      ';background:'+(isActive?'var(--green-light)':'var(--bg3)')+';color:'+(isActive?'var(--green-dark)':canChange?'var(--text)':'var(--text3)')+
      ';font-size:12px;font-weight:'+(isActive?'600':'400')+';cursor:'+(canChange?'pointer':'not-allowed')+
      ';text-align:left;font-family:inherit;opacity:'+(canChange?1:.45)+'">'+(isActive?'✓ ':'')+s+(isActive?' (sekarang)':'')+'</button>';
  }).join('');
  document.getElementById('ov-status').classList.add('open');
}

async function setStatus(id,status){
  var p=projects.find(function(x){return x.id===id});if(!p)return;
  if(p.status===status){closeModal('ov-status');return;}
  if(isTech()&&['Dijadwalkan','Lunas'].indexOf(status)>=0){showToast('Teknisi tidak dapat mengubah ke status ini.','error');closeModal('ov-status');return;}
  if(isStaff()&&status!=='Lunas'){showToast('Staff hanya dapat menandai sebagai Lunas.','error');closeModal('ov-status');return;}
  closeModal('ov-status');
  showLoading('Menyimpan status...');
  var msgs={Proses:'Mulai dikerjakan oleh '+currentUser.name,Selesai:'Pekerjaan selesai — '+currentUser.name,Lunas:'Pembayaran diterima — '+currentUser.name};
  var act={date:today(),text:msgs[status]||'Status → '+status+' oleh '+currentUser.name,done:true};
  p.status=status;
  if(status==='Selesai'||status==='Lunas') p.done_at=today();
  if(!p.timeline)p.timeline=[];
  p.timeline.push(act);

  try {
    var updateObj = {
      id: p.id, status: p.status,
      done_at: p.done_at||null,
      timeline: JSON.stringify(p.timeline)
    };
    await sbUpsert('projects', updateObj);
    hideLoading();
    showToast('Status diperbarui: '+status);
    // Reload dari Supabase agar sync dengan semua user
    await loadProjects();
    showDetail(id);
  } catch(e){hideLoading();showToast('Gagal terhubung.','error');}
  renderTable();renderTable2();updateMetrics();
}

async function deleteProject(id){
  if(!isAdmin()){showToast('Hanya Admin.','error');return;}
  if(!confirm('Hapus proyek ini? Data tidak bisa dikembalikan.'))return;
  showLoading('Menghapus...');
  try {
    await sbDelete('projects', id);
    hideLoading();
    document.getElementById('detail-panel').classList.remove('open');
    await loadProjects();
    showToast('Proyek dihapus.');
  } catch(e){hideLoading();showToast('Gagal terhubung.','error');}
}

