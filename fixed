async function initLogin(){
  // ── DIAGNOSTIK OTOMATIS ──────────────────────────────────────
  var diagEl = document.getElementById('user-chips');

  // Cek 1: URL masih placeholder?
  if(SUPABASE_URL.includes('XXXXXXXXXXXX') || SUPABASE_URL === ''){
    diagEl.innerHTML = diagBox('🔴 SUPABASE_URL belum diisi',
      'Buka file HTML dengan text editor (Notepad/VS Code), cari baris:<br>'+
      '<code>var SUPABASE_URL = \'https://XXXXXXXXXXXX.supabase.co\';</code><br><br>'+
      'Ganti <b>XXXXXXXXXXXX</b> dengan ID project Supabase Anda.<br>'+
      'Contoh: <code>https://abcxyz123456.supabase.co</code>');
    setSyncStatus('err','● Konfigurasi belum diisi');
    return;
  }

  // Cek 2: KEY masih placeholder?
  if(SUPABASE_KEY.includes('XXXXXXXXXX') || SUPABASE_KEY === ''){
    diagEl.innerHTML = diagBox('🔴 SUPABASE_KEY belum diisi',
      'Buka file HTML dengan text editor, cari baris:<br>'+
      '<code>var SUPABASE_KEY = \'eyJ...XXXXXXXXXX\';</code><br><br>'+
      'Ganti dengan <b>anon/public key</b> dari Supabase:<br>'+
      'Dashboard → Settings → API → <b>anon public</b>');
    setSyncStatus('err','● Konfigurasi belum diisi');
    return;
  }

  // Cek 3: Format URL valid?
  if(!SUPABASE_URL.startsWith('https://') || !SUPABASE_URL.includes('.supabase.co')){
    diagEl.innerHTML = diagBox('🔴 Format SUPABASE_URL salah',
      'URL harus dalam format: <code>https://xxxxxxxxxx.supabase.co</code><br>'+
      'URL Anda saat ini: <code>'+SUPABASE_URL+'</code>');
    setSyncStatus('err','● URL tidak valid');
    return;
  }

  // Cek 4: Coba koneksi nyata
  try {
    setSyncStatus('syncing','Menghubungkan ke Supabase...');
    diagEl.innerHTML = '<div style="text-align:center;padding:16px;color:var(--text3);font-size:12px">'+
      '<div class="spinner" style="margin:0 auto 8px;width:20px;height:20px;border-width:2px"></div>'+
      'Menghubungkan ke Supabase...</div>';

    var data = await sbGet('technicians', 'select=id,name,role,spec,phone,pin&order=name.asc');

    if(Array.isArray(data)){
      if(data.length === 0){
        // Terhubung tapi tabel kosong
        diagEl.innerHTML = diagBox('🟡 Terhubung — tapi belum ada pengguna',
          'Koneksi ke Supabase berhasil! Tapi tabel <b>technicians</b> masih kosong.<br><br>'+
          'Jalankan SQL ini di <b>Supabase → SQL Editor</b>:<br><br>'+
          '<code>INSERT INTO technicians (id, name, role, pin) VALUES<br>'+
          "('" + "admin001', 'Admin', 'admin', '1234');</code><br><br>"+
          'Lalu refresh halaman ini.');
        setSyncStatus('ok','● Terhubung (tabel kosong)');
      } else {
        technicians = data;
        apiOnline = true;
        setSyncStatus('ok','● Terhubung');
        renderUserChips();
      }
    } else {
      // Supabase mengembalikan error object
      var errMsg = data.message || data.error || data.hint || JSON.stringify(data);
      var hint = '';
      if(errMsg.includes('relation') && errMsg.includes('does not exist')){
        hint = '<br><br>⚠️ <b>Tabel belum dibuat!</b> Jalankan SQL dari Langkah 3 di Supabase → SQL Editor.';
      } else if(errMsg.includes('JWT') || errMsg.includes('Invalid API key')){
        hint = '<br><br>⚠️ <b>SUPABASE_KEY salah!</b> Pastikan menggunakan <b>anon/public</b> key (bukan service_role key).';
      } else if(errMsg.includes('policy') || errMsg.includes('permission')){
        hint = '<br><br>⚠️ <b>RLS Policy belum diset!</b> Jalankan SQL dari Langkah 4 di Supabase → SQL Editor.';
      }
      diagEl.innerHTML = diagBox('🔴 Error dari Supabase', 'Pesan error: <code>'+errMsg+'</code>'+hint);
      setSyncStatus('err','● Error Supabase');
    }
  } catch(e) {
    apiOnline = false;
    setSyncStatus('err','● Gagal terhubung');
    var netHint = '';
    if(e.message && e.message.includes('fetch')){
      netHint = '<br><br>Kemungkinan penyebab:<br>'+
        '• URL Supabase salah atau project belum aktif<br>'+
        '• Tidak ada koneksi internet<br>'+
        '• Project Supabase sedang paused (cek di dashboard)';
    }
    diagEl.innerHTML = diagBox('🔴 Gagal terhubung ke Supabase',
      'Error: <code>'+(e.message||e)+'</code>'+netHint+
      '<br><br>URL yang dicoba: <code>'+SUPABASE_URL+'</code>');
    console.error('Supabase connection error:', e);
  }
}

