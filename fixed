async function loadTechs(){
  try {
    var data = await sbGet('technicians','select=id,name,role,spec,phone,pin&order=name.asc');
    if(Array.isArray(data)){
      technicians = data;
      updateTechFilter();updateTechFilter2();
      if(document.getElementById('page-teknisi').classList.contains('active'))renderTechList();
    }
  } catch(e){console.warn('loadTechs error',e);}
}

async function loadProjects(){
  setSyncStatus('syncing','Memuat...');
  try {
    var query = 'select=*&order=created_at.desc';
    // Filter by technician if not admin/staff
    if(!isAdmin() && !isStaff()){
      query += '&tech=eq.' + encodeURIComponent(currentUser.name);
    }
    var data = await sbGet('projects', query);
    if(Array.isArray(data)){
      // Parse timeline JSON string jika perlu
      projects = data.map(function(p){
        if(typeof p.timeline === 'string'){try{p.timeline=JSON.parse(p.timeline);}catch(e){p.timeline=[];}}
        if(!p.timeline) p.timeline = [];
        return p;
      });
      apiOnline = true;
      setSyncStatus('ok','● Terhubung');
    } else {
      throw new Error(data.message || 'Gagal');
    }
  } catch(e){
    apiOnline = false;
    setSyncStatus('err','● Koneksi gagal');
    showToast('Gagal memuat data dari Supabase','error');
  }
  renderTable();renderTable2();updateMetrics();
}

