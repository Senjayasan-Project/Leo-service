    <div style="font-size:11px;font-weight:600;margin-bottom:8px">Riwayat Aktivitas</div>
    <div class="tl">
      ${tl || '<div class="tl-text" style="color:var(--text3)">Belum ada aktivitas.</div>'}
    </div>

    <div id="action-buttons" style="display:flex;gap:6px;margin-top:14px;flex-wrap:wrap"></div>
