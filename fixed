// ============================================================
// KALKULASI GAJI TEKNISI
// ============================================================
function renderGajiTeknisi(){
  var bulanEl=document.getElementById('gaji-bulan');
  if(!bulanEl)return;
  var period=bulanEl.value;
  var tarifN=parseFloat(document.getElementById('tarif-normal').value)||50000;
  var tarifT=parseFloat(document.getElementById('tarif-tinggi').value)||75000;
  var tarifM=parseFloat(document.getElementById('tarif-mendesak').value)||100000;

  var techs=technicians.filter(function(t){return t.role==='teknisi'});
  if(!techs.length){document.getElementById('gaji-table').innerHTML='<div class="empty">Belum ada teknisi.</div>';return;}

  var rows=techs.map(function(t){
    var ps=projects.filter(function(p){
      if(p.tech!==t.name)return false;
      if(p.status!=='Selesai'&&p.status!=='Lunas')return false;
      if(period&&p.done_at&&!p.done_at.startsWith(period))return false;
      if(!p.done_at)return false;
      return true;
    });
    var normal=ps.filter(function(p){return(p.priority||'Normal')==='Normal'}).length;
    var tinggi=ps.filter(function(p){return p.priority==='Tinggi'}).length;
    var mendesak=ps.filter(function(p){return p.priority==='Mendesak'}).length;
    var total=ps.length;
    var gaji=(normal*tarifN)+(tinggi*tarifT)+(mendesak*tarifM);
    var init=t.name.split(' ').map(function(w){return w[0]}).join('').slice(0,2).toUpperCase();
    return {t:t,init:init,bg:roleBg[t.role]||'#eef',col:roleCol[t.role]||'#333',
            normal:normal,tinggi:tinggi,mendesak:mendesak,total:total,gaji:gaji};
  }).sort(function(a,b){return b.gaji-a.gaji});

  var totalGajiAll=rows.reduce(function(s,r){return s+r.gaji},0);
  var periodLabel=period?(' — '+period):'(Semua periode)';

  var html='<div style="padding:8px 14px;font-size:11px;color:var(--text3)">'+
    'Tarif: Normal='+fmtRp(tarifN)+' | Tinggi='+fmtRp(tarifT)+' | Mendesak='+fmtRp(tarifM)+periodLabel+'</div>'+
    '<table><thead><tr>'+
    '<th>Teknisi</th><th style="text-align:center">Normal</th><th style="text-align:center">Tinggi</th>'+
    '<th style="text-align:center">Mendesak</th><th style="text-align:center">Total Job</th>'+
    '<th style="text-align:right;color:var(--green-dark)">Est. Gaji</th></tr></thead><tbody>';
  rows.forEach(function(r){
    html+='<tr>'+
      '<td><div style="display:flex;align-items:center;gap:8px">'+
      '<div style="width:28px;height:28px;border-radius:50%;background:'+r.bg+';color:'+r.col+';display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700">'+r.init+'</div>'+
      '<span style="font-weight:600">'+r.t.name+'</span></div></td>'+
      '<td style="text-align:center"><span class="badge b-pend">'+r.normal+'</span></td>'+
      '<td style="text-align:center"><span class="badge b-proc">'+r.tinggi+'</span></td>'+
      '<td style="text-align:center"><span class="badge b-late">'+r.mendesak+'</span></td>'+
      '<td style="text-align:center;font-weight:600">'+r.total+'</td>'+
      '<td style="text-align:right;font-weight:700;color:'+(r.gaji>0?'var(--green-dark)':'var(--text3)')+';font-size:13px">'+fmtRp(r.gaji)+'</td></tr>';
  });
  html+='<tr style="background:var(--bg3);border-top:2px solid var(--border)">'+
    '<td colspan="5" style="font-weight:700;font-size:12px;color:var(--text2)">TOTAL GAJI SEMUA TEKNISI</td>'+
    '<td style="text-align:right;font-weight:700;font-size:14px;color:var(--green-dark)">'+fmtRp(totalGajiAll)+'</td></tr>';
  html+='</tbody></table>';
  document.getElementById('gaji-table').innerHTML=html;
}

// ============================================================
// ANALITIK
// ============================================================
function renderAnalitik(){
  var fin=projects.filter(function(p){return p.done_at});
  var durs=fin.map(function(p){return dayDiff(p.created_at,p.done_at)});
  var avg=durs.length?Math.round(durs.reduce(function(a,b){return a+b},0)/durs.length):0;
  var late=projects.filter(function(p){return p.target&&today()>p.target&&p.status!=='Selesai'&&p.status!=='Lunas'}).length;
  var fi=durs.indexOf(Math.min.apply(null,durs));
  document.getElementById('a-total').textContent=projects.length;
  document.getElementById('a-avg').textContent=avg?avg+' hari':'-';
  document.getElementById('a-fast').textContent=fin[fi]?fin[fi].customer.slice(0,12)+' ('+durs[fi]+'h)':'-';
  document.getElementById('a-late').textContent=late;
  var techs={};projects.forEach(function(p){techs[p.tech]=(techs[p.tech]||0)+1;});
  var maxT=Math.max.apply(null,Object.values(techs).concat([1]));
  document.getElementById('ch-tech').innerHTML=Object.entries(techs).sort(function(a,b){return b[1]-a[1]}).map(function(e){return'<div class="bar-row"><div class="bar-label">'+e[0]+'</div><div class="bar-track"><div class="bar-fill" style="width:'+Math.round(e[1]/maxT*100)+'%"></div></div><div class="bar-val">'+e[1]+'</div></div>'}).join('')||'<div style="color:var(--text3);font-size:12px">Belum ada data</div>';
  var sc={};statusOrder.forEach(function(s){sc[s]=projects.filter(function(p){return p.status===s}).length;});
  var canvas=document.getElementById('donut');var ctx=canvas.getContext('2d');ctx.clearRect(0,0,90,90);
  var start=-Math.PI/2;var tp=Math.max(statusOrder.reduce(function(a,s){return a+sc[s]},0),1);
  statusOrder.forEach(function(s,i){var sl=(sc[s]/tp)*2*Math.PI;ctx.beginPath();ctx.moveTo(45,45);ctx.arc(45,45,38,start,start+sl);ctx.closePath();ctx.fillStyle=sColors[i];ctx.fill();start+=sl;});
  ctx.beginPath();ctx.arc(45,45,22,0,2*Math.PI);ctx.fillStyle='#fff';ctx.fill();
  document.getElementById('donut-leg').innerHTML=statusOrder.map(function(s,i){return'<div class="leg-item"><div class="leg-dot" style="background:'+sColors[i]+'"></div><span style="color:var(--text3)">'+s+'</span><strong style="margin-left:auto">'+sc[s]+'</strong></div>'}).join('');
  var sorted=fin.slice().sort(function(a,b){return dayDiff(a.created_at,a.done_at)-dayDiff(b.created_at,b.done_at)});
  var maxD=Math.max.apply(null,sorted.map(function(p){return dayDiff(p.created_at,p.done_at)}).concat([1]));
  document.getElementById('ch-dur').innerHTML=sorted.slice(0,10).map(function(p){var d=dayDiff(p.created_at,p.done_at);return'<div class="bar-row"><div class="bar-label" style="min-width:90px">'+p.customer.slice(0,12)+'</div><div class="bar-track"><div class="bar-fill" style="width:'+Math.round(d/maxD*100)+'%"></div></div><div class="bar-val">'+d+'h</div></div>'}).join('')||'<div style="color:var(--text3);font-size:12px;padding:8px 0">Belum ada proyek selesai</div>';
  // Init gaji bulan & render
  var gb=document.getElementById('gaji-bulan');if(gb&&!gb.value){var nm=new Date();gb.value=nm.getFullYear()+'-'+String(nm.getMonth()+1).padStart(2,'0');}
  renderGajiTeknisi();
  // Init gaji bulan ke bulan ini & render
  var gb=document.getElementById('gaji-bulan');if(gb&&!gb.value){var nm=new Date();gb.value=nm.getFullYear()+'-'+String(nm.getMonth()+1).padStart(2,'0');}
  renderGajiTeknisi();
}

