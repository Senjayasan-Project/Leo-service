function renderFollowUp(){
  var items=getVisibleProjects().filter(function(p){return p.followup&&p.status!=='Lunas'}).sort(function(a,b){return a.followup.localeCompare(b.followup)});
  var ov=items.filter(function(p){return p.followup<today()}).length;
  var tod=items.filter(function(p){return p.followup===today()}).length;
  var badge=document.getElementById('fu-badge');
  badge.textContent=ov>0?ov+' terlambat':tod>0?tod+' hari ini':'';
  var list=document.getElementById('fu-list');
  if(!items.length){list.innerHTML='<div class="empty">Tidak ada jadwal follow up aktif.</div>';return;}
  list.innerHTML=items.map(function(p){
    var isT=p.followup===today(),isO=p.followup<today();
    return'<div class="fu-card"><div class="fu-date '+(isT?'today':isO?'ov':'')+'">'+(isO?'⚠ Terlambat':isT?'✓ Hari ini':fmt(p.followup))+'</div>'+
      '<div class="fu-info"><div class="fu-proj">'+p.customer+'</div>'+
      '<div class="fu-det">'+p.description.slice(0,55)+' — '+p.tech+' — <span class="badge '+sBadge[p.status]+'">'+p.status+'</span></div></div>'+
      '<button class="abtn g" onclick="showPage(\'dashboard\');setTimeout(function(){showDetail(\''+p.id+'\')},60)">Lihat</button>'+
      (isAdmin()?'<button class="abtn" onclick="snoozeFollowUp(\''+p.id+'\')">+7 Hari</button>':'')+
      '</div>';
  }).join('');
}

async function snoozeFollowUp(id){
  var p=projects.find(function(x){return x.id===id});if(!p||!p.followup)return;
  var d=new Date(p.followup);d.setDate(d.getDate()+7);
  p.followup=d.toISOString().slice(0,10);
  var act={date:today(),text:'Follow up digeser ke '+fmt(p.followup)+' oleh '+currentUser.name,done:true};
  if(!p.timeline)p.timeline=[];p.timeline.push(act);
  try{
    await sbUpsert('projects',{id:p.id,followup:p.followup,timeline:JSON.stringify(p.timeline)});
    renderFollowUp();showToast('Follow up digeser +7 hari');
  }catch(e){showToast('Gagal menyimpan.','error');}
}

