function today(){return new Date().toISOString().slice(0,10)}
function parseSheetDate(d){
  if(!d||d===''||d==='undefined'||d==='-'||d==='0')return null;
  d=String(d).trim();
  if(/^\d{4}-\d{2}-\d{2}$/.test(d))return new Date(d+'T00:00:00');
  var m=d.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if(m){return new Date(m[3]+'-'+m[2].padStart(2,'0')+'-'+m[1].padStart(2,'0')+'T00:00:00');}
  var dt=new Date(d);
  return isNaN(dt.getTime())?null:dt;
}
function toISO(d){var dt=parseSheetDate(d);if(!dt)return '';return dt.toISOString().slice(0,10);}
function dayDiff(a,b){
  var da=parseSheetDate(a)||new Date(a);
  var db=parseSheetDate(b)||new Date(b);
  if(isNaN(da)||isNaN(db))return 0;
  return Math.round((db-da)/86400000);
}
function fmt(d){
  if(!d||d===''||d==='undefined'||d==='-')return'-';
  var dt=parseSheetDate(d);if(!dt)return'-';
  return dt.toLocaleDateString('id-ID',{day:'numeric',month:'short',year:'numeric'});
}
function fmtRp(n){var num=Math.round(Number(n)||0);var s=num.toString();var result='';var rem=s.length%3;for(var i=0;i<s.length;i++){if(i>0&&(i-rem)%3===0)result+='.';result+=s[i];}return'Rp '+result;}
